#!/usr/bin/env bash

# Maintainer: joekamprad
# Description: Set up Sway on a base EndeavourOS install (should work on most arch-based)
# backing up under backup_old_configs_$DATE

set -e  # Exit immediately if a command exits with a non-zero status

# --- Configuration ---
DATE=$(date +%Y%m%d_%H%M%S)
BACKUP_DIR="$HOME/backup_old_configs_$DATE"
SCRIPT_DIR="$HOME/.config/sway/scripts"
REPO_DIR="/tmp/endeavouros-sway-setup"
TOOLS_DIR="/tmp/sway_tools"

echo "-----------------------------------------------"
echo "Starting EndeavourOS Sway Setup Integration"
echo "-----------------------------------------------"

# 1. Create Backups
echo ">> Creating backups in $BACKUP_DIR..."
mkdir -p "$BACKUP_DIR"

# List of critical files/folders to back up
TARGETS=(".config" ".local" ".bashrc" ".gtkrc-2.0" ".icons")

for item in "${TARGETS[@]}"; do
    if [ -e "$HOME/$item" ]; then
        echo "   Backing up $item..."
        cp -rf "$HOME/$item" "$BACKUP_DIR/"
    else
        echo "   $item not found, skipping backup."
    fi
done

# 2. Download Sources
echo ">> Cloning repositories to /tmp..."
git clone https://codeberg.org/joekamprad/endeavouros-sway-setup.git "$REPO_DIR"
git clone https://github.com/killajoe/sway_tools.git "$TOOLS_DIR"

# 3. Install Base Configuration
echo ">> Installing configuration files..."
mkdir -p "$HOME/.config"
mkdir -p "$HOME/.local"
mkdir -p "$HOME/.icons"

# Copying contents to preserve existing non-conflicting files
cp -R "$REPO_DIR"/skel/.config/* "$HOME/.config/"
cp -R "$REPO_DIR"/skel/.local/* "$HOME/.local/"
cp -R "$REPO_DIR"/skel/.icons/* "$HOME/.icons/"
cp "$REPO_DIR"/skel/.bashrc "$HOME/"
# Handle .gtkrc-2.0 gracefully as it might not always be present
cp "$REPO_DIR"/skel/.gtkrc-2.0 "$HOME/" 2>/dev/null || true
cp "$REPO_DIR"/skel/packages-AUR.txt "$HOME/"

# 4. Set up Sway Tools
echo ">> Installing Sway helper scripts..."
mkdir -p "$SCRIPT_DIR"

# SourcePath:DestinationName (if renaming is needed)
TOOLS=(
    "new_workspace/new_workspace"
    "powermenu/powermenu_gracefully:powermenu"
    "gracefully_exit/gracefully_exit"
    "power_profiles_switcher/power-profiles"
    "swaycast/swaycast"
    "swayshot/swayshot"
    "waybar_toggle/waybar_toggle"
    "weather/openweather"
)

for item in "${TOOLS[@]}"; do
    src="${item%%:*}"
    dest="${item#*:}"
    [ "$dest" == "$src" ] && dest=$(basename "$src")
    cp "$TOOLS_DIR/$src" "$SCRIPT_DIR/$dest"
done

# NEW: Copy the Rofi theme for the power profiles switcher
echo ">> Installing Rofi themes for tools..."
mkdir -p "$HOME/.config/rofi"
cp "$TOOLS_DIR/power_profiles_switcher/power-profile.rasi" "$HOME/.config/rofi/"

# Make all scripts in the directory executable
chmod -R +x "$SCRIPT_DIR"

# 5. System Packages and Services
echo ">> Installing system dependencies (sudo required)..."
sudo pacman -S --needed --noconfirm - < "$REPO_DIR/etc/skel/packages-repository.txt"

echo ">> Enabling LY login Manager service..."
sudo systemctl enable ly@tty2.service
sudo systemctl disable getty@tty2.service
sudo systemctl enable swayosd-libinput-backend.service

# 6. Cleanup
echo ">> Cleaning up temporary files..."
rm -rf "$REPO_DIR" "$TOOLS_DIR"

echo "-----------------------------------------------"
echo "Setup complete!"
echo "Backups are located in: $BACKUP_DIR"
echo "Please reboot your system to log into Sway."
echo "-----------------------------------------------"