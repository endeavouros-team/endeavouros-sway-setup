#!/usr/bin/env bash

# Maintainer: joekamprad
# Description: Set up Sway on a base EndeavourOS install (should work on most arch-based)
# backing up under backup_old_configs_$DATE

set -e  # Exit immediately if a command exits with a non-zero status

# --- Configuration ---
DATE=$(date +%Y%m%d_%H%M%S)
BACKUP_DIR="$HOME/backup_old_configs_$DATE"
SCRIPT_DIR="$HOME/.local/bin"
REPO_DIR="/tmp/endeavouros-sway-setup"
TOOLS_DIR="/tmp/sway_tools"

echo "-----------------------------------------------"
echo "Starting EndeavourOS Sway Setup Integration"
echo "-----------------------------------------------"

# 1. Create Backups
echo ">> Creating backups in $BACKUP_DIR..."
mkdir -p "$BACKUP_DIR"

# List of critical files/folders to back up
TARGETS=(".config" ".local" ".gtkrc-2.0" ".icons" ".profile")

for item in "${TARGETS[@]}"; do
    if [ -e "$HOME/$item" ]; then
        echo "   Backing up $item..."
        cp -rf "$HOME/$item" "$BACKUP_DIR/"
    else
        echo "   $item not found, skipping backup."
    fi
done

# 2. Download Sources
echo ">> Cloning repositories to /tmp..."
git clone https://github.com/endeavouros-team/endeavouros-sway-setup.git "$REPO_DIR"
git clone https://github.com/killajoe/sway_tools.git "$TOOLS_DIR"

# 3. Install Base Configuration
echo ">> Installing system dependencies (sudo required)..."
sudo pacman -S --needed --noconfirm - < "$REPO_DIR/packages-repository.txt"

echo ">> installing config files..."
cp -R "$REPO_DIR"/skel/.config/* "$HOME/.config/"
cp -R "$REPO_DIR"/skel/.local/* "$HOME/.local/"
cp -R "$REPO_DIR"/skel/.icons/* "$HOME/.icons/"
# Handle .gtkrc-2.0 gracefully as it might not always be present
cp "$REPO_DIR"/skel/.gtkrc-2.0 "$HOME/.gtkrc-2.0" 2>/dev/null || true
cp "$REPO_DIR"/skel/.profile "$HOME/.profile" 2>/dev/null || true
echo ">> make xed nice looking..."
dbus-launch dconf load / < "$REPO_DIR"/xed.dconf
rm "$REPO_DIR"/xed.dconf
echo ">> remove not needed set_once from sway config"
sed -i 's|\(exec ~/set_once.sh\)|# \1|' "$HOME/.config/sway/config"

# 4. Set up Sway Tools
echo ">> Installing Sway helper scripts..."
mkdir -p "$SCRIPT_DIR"

# Mapping: SourcePath:DestinationName
TOOLS=(
    "new_workspace/sway-new-workspace"
    "powermenu/sway-powermenu-gracefully"
    "gracefully_exit/sway-gracefully-exit"
    "power_profiles_switcher/sway-power-profiles"
    "swaycast/swaycast"
    "swayshot/swayshot"
    "waybar_toggle/waybar-toggle"
    "weather/sway-openweather"
)
for src in "${TOOLS[@]}"; do
    # Extract the filename from the path (e.g., "sway-new-workspace")
    dest=$(basename "$src")
    cp "$TOOLS_DIR/$src" "$SCRIPT_DIR/$dest"
done

# switch name for powermenu
mv "$SCRIPT_DIR/sway-powermenu-gracefully" "$SCRIPT_DIR/sway-powermenu"

# Copy Rofi theme for power profiles and powermenu
mkdir -p "$HOME/.config/rofi/"
cp "$TOOLS_DIR/power_profiles_switcher/power-profiles.rasi" "$HOME/.config/rofi/"
cp "$TOOLS_DIR/powermenu/powermenu.rasi" "$HOME/.config/rofi/"

# Make all scripts in the directory executable
chmod -R +x "$SCRIPT_DIR"

# 5. Set up greetd greeter tuigreet

if [ ! -f "$REPO_DIR/config.toml" ]; then
    echo "ERROR: Source configuration file not found at: $REPO_DIR/config.toml" >&2
    exit 1
fi

if [ -f "/etc/greetd/config.toml" ]; then
    echo "====================================================================="
    echo "WARNING: An existing greetd configuration was found."
    echo "A backup will be created at: /etc/greetd/config.toml.bak"
    echo "The /etc/greetd/config.toml will be overwritten with the prepared version."
    echo "====================================================================="

    # Execute backup with root privileges
    if sudo cp "/etc/greetd/config.toml" "/etc/greetd/config.toml.bak"; then
        echo "==> Backup successfully created."
    else
        echo "ERROR: Failed to create backup. Aborting." >&2
        exit 1
    fi

    # Execute file copy with root privileges
    if sudo cp "$REPO_DIR/config.toml" "/etc/greetd/config.toml"; then
        echo "==> /etc/greetd/config.toml has been successfully updated from repository."
    else
        echo "ERROR: Failed to copy the configuration file." >&2
        exit 1
    fi
else
    echo "ERROR: /etc/greetd/config.toml not found. Is greetd installed?" >&2
    exit 1
fi

# 6. System Services
echo ">> enable greetd and swayosd-libinput service..."

sudo systemctl enable greetd.service
sudo systemctl enable swayosd-libinput-backend.service

# 7. adding sway session starter with Nvidia Driver support
sudo cp "$REPO_DIR/eos-sway.desktop" "/usr/share/wayland-sessions/"
sudo cp "$REPO_DIR/eos-sway-wrapper" "/usr/bin/"
sudo chmod +x "/usr/bin/eos-sway-wrapper"


# 8. Cleanup
echo ">> Cleaning up temporary files..."
rm -rf "$REPO_DIR" "$TOOLS_DIR"

echo "-----------------------------------------------"
echo "Setup complete!"
echo "Backups are located in: $BACKUP_DIR"
echo "Please reboot your system to log into Sway."
echo "-----------------------------------------------"
