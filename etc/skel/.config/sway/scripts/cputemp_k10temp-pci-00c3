#!/bin/bash

# Nur die Zeilen mit k10temp-pci-00c3 und den drei Temperaturen holen
output=$(sensors k10temp-pci-00c3 | grep -E 'Tctl|Tccd1|Tccd2')

# Extrahiere die Temperaturwerte (mit Komma oder Punkt)
temps=$(echo "$output" | grep -oP '\+\d+(\.\d+)?' | tr -d '+')

max_temp=0
max_temp_float=0

for t in $temps; do
  cmp=$(echo "$t > $max_temp_float" | bc)
  if [ "$cmp" -eq 1 ]; then
    max_temp_float=$t
  fi
done

echo "${max_temp_float}°C"

