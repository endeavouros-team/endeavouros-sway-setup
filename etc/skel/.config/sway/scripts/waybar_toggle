#!/usr/bin/env bash

STATEFILE="/tmp/waybar_toggle.state"

if pgrep -x waybar > /dev/null; then
    # Waybar läuft → kill
    killall waybar
    echo "off" > "$STATEFILE"
else
    # Waybar läuft nicht → alle JSONC starten
    for cfg in ~/.config/waybar/*.jsonc; do
        # Nur existierende Dateien
        [[ -f "$cfg" ]] || continue

        # Basisname ohne Endung
        base="${cfg%.jsonc}"
        style="${base}.css"

        if [[ -f "$style" ]]; then
            waybar -c "$cfg" -s "$style" &
        else
            waybar -c "$cfg" &
        fi
    done
    echo "on" > "$STATEFILE"
fi


