#!/bin/bash

# Define possible lock scripts/commands (edit this list as you like)
LOCK_SCRIPTS=("swaylock" "swaylock-effects" "i3lock" "~/.config/sway/scripts/lock.sh")

# Find available lock script
find_lock_script() {
    for script in "${LOCK_SCRIPTS[@]}"; do
        # Handle command names vs full paths
        if [[ "$script" =~ ^[a-zA-Z0-9_-]+$ ]]; then
            # It's a command name, check if available
            if command -v "$script" >/dev/null 2>&1; then
                echo "$script"
                return 0
            fi
        else
            # It's a path, check if file exists and is executable
            if [[ -x "$script" ]]; then
                echo "$script"
                return 0
            fi
        fi
    done
    return 1
}

# Menu entries
lock="´Çú  Lock"
logout="´íé  Logout"
reboot="´Ç×  Reboot"
shutdown="´Çæ  Shutdown"
suspend="´åå  Suspend"
hibernate="´ï£  Hibernate"

# Add lock only if script is found
if lockcmd="$(find_lock_script)"; then
    options="$lock\n$logout\n$reboot\n$shutdown\n$suspend\n$hibernate"
else
    options="$logout\n$reboot\n$shutdown\n$suspend\n$hibernate"
fi

chosen="$(echo -e "$options" | rofi -dmenu -i -p "Power Menu" \
    -theme ~/.config/rofi/powermenu.rasi)"

case $chosen in
    "$lock")
        $lockcmd
        ;;
    "$logout")
        swaymsg exit
        ;;
    "$reboot")
        systemctl reboot
        ;;
    "$shutdown")
        systemctl poweroff
        ;;
    "$suspend")
        systemctl suspend
        ;;
    "$hibernate")
        systemctl hibernate
        ;;
esac
