#!/usr/bin/env bash

# simple yad gui to show default EndeavourOS sway keybindings

Main() {

    local command=(
        yad --title="EndeavourOS SWAY keybindings:" --no-buttons --geometry=400x300-15-400 --list
        --column-align="lcc"
        --header-align="ccc"
        --column="key combination" --column="description" --column=""
        "ESC" "close this app" "пБЧ"
        "пЕЉ=пЕЇ" "set mod-key to the win-key" "пЕЉ"
        "пЕЉ+enter" "open a terminal" "пД†"
        "пЕЉ+Shift+n" "new empty workspace" "пЛТ"
        "пЕЉ+w" "open Browser" "пЙ©"
        "пЕЉ+n" "open Filebrowser" "пБЉ"
        "пЕЉ+d" "app menu" "пЕЭ"
        "пЕЉ+q" "close focused app" "пЛФ"
        "Print-key" "screenshot" "пЗЕ"
        "пЕЉ+Shift+e" "logout menu" "пКН"
        "F1" "open keybinding helper" "пБЪ"
    )

    "${command[@]}"
}

Main "$@"
