#!/usr/bin/env bash
# Maintainer: joekamprad [joekamprad //a_t// endeavouros.com]
# This is to be used inside EndeavourOS ISO livesession
# Adding it as custom install-script to Welcome and it will install on target
# make sure to choose No-Desktop option.

set -e  # Exit on error

# --- Configuration ---
USER_NAME="$1"
USER_HOME="/home/$USER_NAME"
REPO_DIR="/tmp/endeavouros-sway-setup"
TOOLS_DIR="/tmp/sway_tools"
SCRIPT_DIR="$USER_HOME/.config/sway/scripts"

# Validation: Ensure a username was provided
if [ -z "$USER_NAME" ]; then
    echo "Error: No username provided. Usage: $0 <username>"
    exit 1
fi

echo "-----------------------------------------------"
echo "Installing Sway Environment for user: $USER_NAME"
echo "-----------------------------------------------"

# 1. Download Sources to /tmp (ISO RAM)
echo ">> Downloading resources..."
git clone https://codeberg.org/joekamprad/endeavouros-sway-setup.git "$REPO_DIR"
git clone https://github.com/killajoe/sway_tools.git "$TOOLS_DIR"

# 2. Prepare Directory Structure
echo ">> Preparing directories in $USER_HOME..."
mkdir -p "$USER_HOME/.config/rofi"
mkdir -p "$USER_HOME/.local"
mkdir -p "$USER_HOME/.icons"
mkdir -p "$SCRIPT_DIR"

# 3. Install Base Configuration
echo ">> Deploying skel files..."
cd "$REPO_DIR/etc/skel/"

# Use -a (archive) to preserve attributes during copy
cp -ar .config .local .icons "$USER_HOME/"
cp .bashrc .gtkrc-2.0 packages-AUR.txt "$USER_HOME/"
cp ../../force-knowledge.md "$USER_HOME/.config/sway/readme.md"

# 4. Install Sway Tools
echo ">> Deploying Sway Tools..."

# Mapping: SourcePath:DestinationName
TOOLS=(
    "new_workspace/new_workspace"
    "powermenu/powermenu_gracefully:powermenu"
    "gracefully_exit/gracefully_exit"
    "power_profiles_switcher/power-profiles"
    "swaycast/swaycast"
    "swayshot/swayshot"
    "waybar_toggle/waybar_toggle"
    "weather/openweather"
)

for item in "${TOOLS[@]}"; do
    src="${item%%:*}"
    dest="${item#*:}"
    [ "$dest" == "$src" ] && dest=$(basename "$src")
    cp "$TOOLS_DIR/$src" "$SCRIPT_DIR/$dest"
done

# Copy Rofi theme for power profiles
cp "$TOOLS_DIR/power_profiles_switcher/power-profile.rasi" "$USER_HOME/.config/rofi/"

# 5. Permissions and Executables
echo ">> Setting permissions..."
chmod -R +x "$SCRIPT_DIR"
# CRITICAL: Fix ownership because git/cp were run as root in the ISO
chown -R "$USER_NAME:$USER_NAME" "$USER_HOME"

# 6. System Packages and Services
echo ">> Installing packages and enabling services..."
# Note: In ISO context, we don't need sudo as the installer runs as root
pacman -S --needed --noconfirm - < "$REPO_DIR/etc/skel/packages-repository.txt"

systemctl enable ly@tty2.service
systemctl disable getty@tty2.service
systemctl enable swayosd-libinput-backend.service

# 7. Cleanup
echo ">> Cleaning up..."
rm -rf "$REPO_DIR" "$TOOLS_DIR"

echo "-----------------------------------------------"
echo "ISO Installation Step Complete for $USER_NAME"
echo "-----------------------------------------------"
