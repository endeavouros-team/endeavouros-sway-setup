#!/usr/bin/env bash
# Maintainer: joekamprad [joekamprad //a_t// endeavouros.com]
# This is to be used inside EndeavourOS ISO livesession
# Adding it as custom install-script to Welcome and it will install on target
# make sure to choose No-Desktop option. 

username="$1"
git clone https://codeberg.org/joekamprad/endeavouros-sway-setup.git
cd endeavouros-sway-setup/etc/skel/
cp -R .config .local .icons /home/$username/
cp  .bashrc .gtkrc-2.0 packages-AUR.txt /home/$username/
cp ../../force-knowledge.md "/home/$username/.config/sway/readme.md"
git clone https://github.com/killajoe/sway_tools.git
cp sway_tools/new_workspace/new_workspace /home/$username/config/sway/scripts/
# using gracefully powermenu needs gracefully_exit script
cp sway_tools/powermenu/powermenu_gracefully /home/$username/.config/sway/scripts/powermenu
cp sway_tools/gracefully_exit/gracefully_exit /home/$username/.config/sway/scripts/
cp sway_tools/power_profiles_switcher/power-profiles /home/$username/.config/sway/scripts/
cp sway_tools/power_profiles_switcher/power-profiles.rasi /home/$username/.config/rofi/power-profiles.rasi
cp sway_tools/swaycast/swaycast /home/$username/.config/sway/scripts/
cp sway_tools/swayshot/swayshot /home/$username/.config/sway/scripts/
cp sway_tools/waybar_toggle/waybar_toggle /home/$username/.config/sway/scripts/
cp sway_tools/weather/openweather /home/$username/.config/sway/scripts/
chown -R $username:$username /home/$username
chmod -R +x /home/$username/.config/sway/scripts
pacman -S --needed --noconfirm - < packages-repository.txt 
cd /
rm -R endeavouros-sway-setup
# start DM (ly)
systemctl enable ly@tty2.service
# disable TTY2 to be free for ly
systemctl disable getty@tty2.service
# needed for swayosd
systemctl enable swayosd-libinput-backend.service
