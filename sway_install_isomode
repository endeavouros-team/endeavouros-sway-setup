#!/usr/bin/env bash

# Maintainer: joekamprad [joekamprad //a_t// endeavouros.com]
# This is to be used inside EndeavourOS ISO livesession
# Adding it as custom install-script to Welcome and it will install on target
# make sure to choose No-Desktop option.

set -e  # Exit on error

# --- Configuration ---
USER_NAME="$1"
USER_HOME="/home/$USER_NAME"
REPO_DIR="/tmp/endeavouros-sway-setup"
TOOLS_DIR="/tmp/sway_tools"
SCRIPT_DIR="$USER_HOME/.local/bin"

# Validation: Ensure a username was provided
if [ -z "$USER_NAME" ]; then
    echo "Error: No username provided. Usage: $0 <username>"
    exit 1
fi

echo "-----------------------------------------------"
echo "Installing Sway Environment for user: $USER_NAME"
echo "-----------------------------------------------"

# 1. Download Sources to /tmp (ISO RAM)
echo ">> Downloading resources..."
git clone https://github.com/endeavouros-team/endeavouros-sway-setup.git "$REPO_DIR"
git clone https://github.com/killajoe/sway_tools.git "$TOOLS_DIR"


# 3. System Packages and Services
echo ">> Installing packages "

pacman -S --needed --noconfirm - < "$REPO_DIR/packages-repository.txt"

# 4. Install Base Configuration
echo ">> installing config files..."

# copy configs and files.
cp -ar "$REPO_DIR/skel/.config" "$REPO_DIR/skel/.local" "$REPO_DIR/skel/.icons" "$USER_HOME/"
cp "$REPO_DIR/skel/.gtkrc-2.0" "$REPO_DIR/skel/.profile" "$USER_HOME/"
cp "$REPO_DIR/force-knowledge.md" "$USER_HOME/.config/sway/readme.md"

# 5. Install Sway Tools
echo ">> Deploying Sway Tools..."
mkdir -p "$SCRIPT_DIR"

# Mapping: SourcePath:DestinationName
TOOLS=(
    "new_workspace/sway-new-workspace"
    "powermenu/sway-powermenu-gracefully"
    "gracefully_exit/sway-gracefully-exit"
    "power_profiles_switcher/sway-power-profiles"
    "swaycast/swaycast"
    "swayshot/swayshot"
    "waybar_toggle/waybar-toggle"
    "weather/sway-openweather"
)

for item in "${TOOLS[@]}"; do
    src="${item%%:*}"
    dest="${item#*:}"
    [ "$dest" == "$src" ] && dest=$(basename "$src")
    cp "$TOOLS_DIR/$src" "$SCRIPT_DIR/$dest"
done

# switch name for powermenu
mv "$SCRIPT_DIR/sway-powermenu-gracefully" "$SCRIPT_DIR/sway-powermenu"

# Copy Rofi theme for power profiles and powermenu
cp "$TOOLS_DIR/power_profiles_switcher/power-profiles.rasi" "$USER_HOME/.config/rofi/"
cp "$TOOLS_DIR/powermenu/powermenu.rasi" "$USER_HOME/.config/rofi/"

# 6. Permissions and Executables
echo ">> Setting permissions..."
chmod -R +x "$SCRIPT_DIR"
# only till i switched all scripts over to .local/bin
chmod -R +x ""$USER_HOME/.config/sway/scripts"

# CRITICAL: Fix ownership because git/cp were run as root in the ISO
chown -R "$USER_NAME:$USER_NAME" "$USER_HOME"

# 7. Set up greetd greeter tuigreet

if [ ! -f "$REPO_DIR/config.toml" ]; then
    echo "ERROR: Source configuration file not found at: $REPO_DIR/config.toml" >&2
    exit 1
fi

if [ -f "/etc/greetd/config.toml" ]; then
    echo "====================================================================="
    echo "WARNING: An existing greetd configuration was found."
    echo "A backup will be created at: /etc/greetd/config.toml.bak"
    echo "The /etc/greetd/config.toml will be overwritten with the prepared version."
    echo "====================================================================="

    if cp "/etc/greetd/config.toml" "/etc/greetd/config.toml.bak"; then
        echo "==> Backup successfully created."
    else
        echo "ERROR: Failed to create backup. Aborting." >&2
        exit 1
    fi

    if cp "$REPO_DIR/config.toml" "/etc/greetd/config.toml"; then
        echo "==> /etc/greetd/config.toml has been successfully updated from repository."
    else
        echo "ERROR: Failed to copy the configuration file." >&2
        exit 1
    fi
else
    echo "ERROR: /etc/greetd/config.toml not found. Is greetd installed?" >&2
    exit 1
fi

# 8. System Services
echo ">> enable greetd and swayosd-libinput service..."

systemctl enable greetd.service
systemctl enable swayosd-libinput-backend.service

# 9. adding sway session starter with Nvidia Driver support
cp "$REPO_DIR/eos-sway.desktop" "/usr/share/wayland-sessions/"
cp "$REPO_DIR/eos-sway-wrapper" "/usr/bin/"
chmod +x "/usr/bin/eos-sway-wrapper"

# 10. Cleanup
echo ">> Cleaning up..."
rm -rf "$REPO_DIR" "$TOOLS_DIR"

echo "-----------------------------------------------"
echo "Sway Installation Complete for $USER_NAME"
echo "-----------------------------------------------"
